{
  "crons": [
    {
      "path": "/api/admin-generate-drafts?schedule=auto&track=multi&excludeSections=health,entertainment,technology",
      "schedule": "5 * * * *"
    },
    {
      "path": "/api/admin-generate-drafts?schedule=auto&track=single&includeSections=health,entertainment,technology",
      "schedule": "5 10,14 * * *"
    },
    {
      "path": "/api/admin-generate-drafts?schedule=auto&track=multi&provider=openai&excludeSections=health,entertainment,technology",
      "schedule": "25 * * * *"
    },
    {
      "path": "/api/admin-generate-drafts?schedule=auto&track=single&provider=openai&includeSections=health,entertainment,technology",
      "schedule": "25 10,14 * * *"
    },
    {
      "path": "/api/admin-generate-drafts?schedule=auto&track=multi&provider=gemini&excludeSections=health,entertainment,technology",
      "schedule": "45 * * * *"
    },
    {
      "path": "/api/admin-generate-drafts?schedule=auto&track=single&provider=gemini&includeSections=health,entertainment,technology",
      "schedule": "45 10,14 * * *"
    },
    {
      "path": "/api/admin-generate-drafts?schedule=auto&track=multi&provider=grok&excludeSections=health,entertainment,technology",
      "schedule": "55 * * * *"
    },
    {
      "path": "/api/admin-generate-drafts?schedule=auto&track=single&provider=grok&includeSections=health,entertainment,technology",
      "schedule": "55 10,14 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
